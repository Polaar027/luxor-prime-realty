# Copy this file to .env and fill in real values.
# Not required to run the app today — the app currently runs on an
# in-memory JSON data layer (lib/data/repository.ts). DATABASE_URL is only
# needed once you switch repository.ts over to @prisma/client.

# Get a free Postgres instance from Neon (neon.tech) or Supabase (supabase.com),
# or run Postgres locally / via Docker.
DATABASE_URL="postgresql://user:password@localhost:5432/luxor_prime_realty"

# Used later for admin auth (Phase: Admin Panel)
JWT_SECRET="replace-with-a-long-random-string"

# Used later for image uploads (Phase: Admin Panel / Development Details)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME=""

# Used later for currency conversion (Phase: Financial Tools)
EXCHANGE_RATE_API_KEY=""
